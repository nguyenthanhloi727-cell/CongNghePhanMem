@{
    ViewData["Title"] = "Asset Management";
}

<div class="card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-3 w-50">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Search assets...">
            </div>
            <select class="form-select w-50">
                <option selected>All Categories</option>
                <option value="1">Electronics</option>
                <option value="2">Furniture</option>
            </select>
        </div>
        <button class="btn btn-primary" style="background-color: #4b4efc; border-color: #4b4efc;">
            <i class="bi bi-plus me-1"></i> Add New Asset
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col" class="ps-3 py-3">ASSET ID</th>
                    <th scope="col" class="py-3">NAME</th>
                    <th scope="col" class="py-3">CATEGORY</th>
                    <th scope="col" class="py-3">STATUS</th>
                    <th scope="col" class="py-3">LOCATION</th>
                    <th scope="col" class="text-end pe-3 py-3">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-3 fw-bold">#AST-1042</td>
                    <td>Sony Projector X200</td>
                    <td><span class="badge text-primary" style="background-color: #e0e7ff;">Electronics</span></td>
                    <td><span class="badge text-success" style="background-color: #d1fae5;">Active</span></td>
                    <td class="text-muted">Room 101</td>
                    <td class="text-end pe-3 text-muted">
                        <i class="bi bi-pencil-square me-2" style="cursor: pointer;"></i>
                        <i class="bi bi-trash" style="cursor: pointer;"></i>
                    </td>
                </tr>
                <tr>
                    <td class="ps-3 fw-bold">#AST-1043</td>
                    <td>Dell Optiplex 7090</td>
                    <td><span class="badge text-primary" style="background-color: #e0e7ff;">Electronics</span></td>
                    <td><span class="badge text-warning" style="background-color: #fef3c7;">Maintenance</span></td>
                    <td class="text-muted">Lab A</td>
                    <td class="text-end pe-3 text-muted">
                        <i class="bi bi-pencil-square me-2" style="cursor: pointer;"></i>
                        <i class="bi bi-trash" style="cursor: pointer;"></i>
                    </td>
                </tr>
                <tr>
                    <td class="ps-3 fw-bold">#AST-1044</td>
                    <td>Teacher Desk Oak</td>
                    <td><span class="badge text-purple" style="color: #9333ea; background-color: #f3e8ff;">Furniture</span></td>
                    <td><span class="badge text-success" style="background-color: #d1fae5;">Active</span></td>
                    <td class="text-muted">Room 102</td>
                    <td class="text-end pe-3 text-muted">
                        <i class="bi bi-pencil-square me-2" style="cursor: pointer;"></i>
                        <i class="bi bi-trash" style="cursor: pointer;"></i>
                    </td>
                </tr>
                <tr>
                    <td class="ps-3 fw-bold border-bottom-0">#AST-1045</td>
                    <td class="border-bottom-0">Whiteboard 2x1.5m</td>
                    <td class="border-bottom-0"><span class="badge text-purple" style="color: #9333ea; background-color: #f3e8ff;">Furniture</span></td>
                    <td class="border-bottom-0"><span class="badge text-danger" style="background-color: #fee2e2;">Broken</span></td>
                    <td class="border-bottom-0 text-muted">Room 205</td>
                    <td class="border-bottom-0 text-end pe-3 text-muted">
                        <i class="bi bi-pencil-square me-2" style="cursor: pointer;"></i>
                        <i class="bi bi-trash" style="cursor: pointer;"></i>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
