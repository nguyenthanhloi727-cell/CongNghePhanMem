@{
    ViewData["Title"] = "User Roles & Permissions";
}

<div class="card p-0 overflow-hidden">
    <div class="d-flex justify-content-end p-4 pb-0">
        <button class="btn btn-primary px-4" style="background-color: #4b4efc; border-color: #4b4efc;">
            Save Changes
        </button>
    </div>
    <div class="card-body p-4 pt-3">
        <div class="table-responsive border rounded-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th scope="col" class="ps-4 py-3 border-bottom">USER NAME</th>
                        <th scope="col" class="py-3 border-bottom">EMAIL</th>
                        <th scope="col" class="py-3 border-bottom">ROLE</th>
                        <th scope="col" class="text-center py-3 border-bottom">VIEW</th>
                        <th scope="col" class="text-center py-3 border-bottom">EDIT</th>
                        <th scope="col" class="text-center py-3 border-bottom">DELETE</th>
                        <th scope="col" class="text-center pe-4 py-3 border-bottom">REPORT</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; font-size: 0.9rem;">
                                    J
                                </div>
                                <span class="fw-medium">John Doe</span>
                            </div>
                        </td>
                        <td class="text-muted">john@edu.com</td>
                        <td>
                            <select class="form-select form-select-sm text-muted" style="width: 120px;">
                                <option selected>Admin</option>
                                <option>Teacher</option>
                                <option>Staff</option>
                            </select>
                        </td>
                        <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center pe-4"><input class="form-check-input" type="checkbox" checked></td>
                    </tr>
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; font-size: 0.9rem;">
                                    S
                                </div>
                                <span class="fw-medium">Sarah Smith</span>
                            </div>
                        </td>
                        <td class="text-muted">sarah@edu.com</td>
                        <td>
                            <select class="form-select form-select-sm text-muted" style="width: 120px;">
                                <option>Admin</option>
                                <option selected>Teacher</option>
                                <option>Staff</option>
                            </select>
                        </td>
                        <td class="text-center"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                        <td class="text-center"><input class="form-check-input" type="checkbox"></td>
                        <td class="text-center pe-4"><input class="form-check-input" type="checkbox"></td>
                    </tr>
                    <tr>
                        <td class="ps-4 py-3 border-bottom-0">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px; font-size: 0.9rem;">
                                    M
                                </div>
                                <span class="fw-medium">Mike Johnson</span>
                            </div>
                        </td>
                        <td class="border-bottom-0 text-muted">mike@edu.com</td>
                        <td class="border-bottom-0">
                            <select class="form-select form-select-sm text-muted" style="width: 120px;">
                                <option>Admin</option>
                                <option>Teacher</option>
                                <option selected>Staff</option>
                            </select>
                        </td>
                        <td class="text-center border-bottom-0"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center border-bottom-0"><input class="form-check-input" type="checkbox" checked></td>
                        <td class="text-center border-bottom-0"><input class="form-check-input" type="checkbox"></td>
                        <td class="text-center pe-4 border-bottom-0"><input class="form-check-input" type="checkbox" checked></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
