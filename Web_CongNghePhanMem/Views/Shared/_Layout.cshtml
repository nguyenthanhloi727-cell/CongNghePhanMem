<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduAsset</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web_CongNghePhanMem.styles.css" asp-append-version="true" />
</head>
<body class="bg-light" style="font-family: 'Inter', sans-serif;">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-white" id="sidebar-wrapper" style="width: 250px; min-height: 100vh;">
            <div class="sidebar-heading bg-white d-flex align-items-center px-4 py-4 mb-3 border-end">
                <span class="fs-5 fw-bold" style="color: #4b4efc;"><i class="bi bi-buildings-fill me-2"></i> EduAsset</span>
            </div>
            <div class="list-group list-group-flush px-3 gap-2">
                <a class="list-group-item list-group-item-action border-0 rounded-3 fw-medium py-2 px-3 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active-nav" : "text-muted")" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door-fill me-2 fs-5 align-middle"></i> Dashboard
                </a>
                <a class="list-group-item list-group-item-action border-0 rounded-3 fw-medium py-2 px-3 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Assets" ? "active-nav" : "text-muted")" asp-controller="Home" asp-action="Assets">
                    <i class="bi bi-boxes me-2 fs-5 align-middle"></i> Assets
                </a>
                <a class="list-group-item list-group-item-action border-0 rounded-3 fw-medium py-2 px-3 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Roles" ? "active-nav" : "text-muted")" asp-controller="Home" asp-action="Roles">
                    <i class="bi bi-people-fill me-2 fs-5 align-middle"></i> Roles & Permissions
                </a>
                <a class="list-group-item list-group-item-action border-0 rounded-3 fw-medium py-2 px-3 @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reports" ? "active-nav" : "text-muted")" asp-controller="Home" asp-action="Reports">
                    <i class="bi bi-bar-chart-fill me-2 fs-5 align-middle"></i> Reports
                </a>
            </div>
            <!-- Hack to fill the rest of the height with border-end -->
            <div class="border-end h-100" style="position: absolute; right: 0; top: 0; bottom: 0; width: 1px; z-index: -1;"></div>
        </div>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="flex-grow-1" style="min-width: 0;">
            <nav class="navbar navbar-expand-lg navbar-light bg-white px-4 py-3 border-bottom sticky-top">
                <div class="container-fluid px-0">
                    <h4 class="mb-0 fw-bold" style="color: #1f2937;">@ViewData["Title"]</h4>
                    <div class="d-flex align-items-center ms-auto">
                        <button class="btn btn-link text-muted p-2 me-3 rounded-circle" style="background-color: #f3f4f6;">
                            <i class="bi bi-bell-fill"></i>
                        </button>
                        <div class="rounded-circle text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; font-weight: 600; font-size: 1.1rem; background-color: #4b4efc; cursor: pointer;">
                            A
                        </div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid p-4" style="background-color: #f8f9fa;">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
